# =============================================================================
# Solana Sniper Bot - Environment Configuration
# =============================================================================
# Copy ke .env (or secrets/.env), isi dengan credential asli.
# JANGAN PERNAH commit .env ke git.
# Set permission: chmod 600 .env
# =============================================================================

# --- Mode ---
DRY_RUN=true                          # WAJIB true sampai backtest valid + smoke test sukses
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
ENV=development                       # development | production

# --- Helius ---
HELIUS_API_KEY=replace_with_helius_api_key
# URL constructed at runtime; jangan ganti template ini kecuali tahu konsekuensinya
HELIUS_RPC_URL=https://mainnet.helius-rpc.com
HELIUS_WSS_URL=wss://mainnet.helius-rpc.com

# --- GMGN ---
GMGN_API_KEY=replace_with_gmgn_api_key
GMGN_PRIVATE_KEY_PATH=secrets/gmgn_private.pem
GMGN_BASE_URL=https://gmgn.ai

# --- Solana Wallet ---
WALLET_PATH=secrets/bot-wallet.json
WALLET_PUBLIC_KEY=replace_with_bot_wallet_public_address
SOLANA_RPC_URL=https://mainnet.helius-rpc.com  # akan diisi otomatis kalau pakai Helius

# --- Telegram ---
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_CHAT_ID=replace_with_chat_id

# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=solana_bot
POSTGRES_USER=bot
POSTGRES_PASSWORD=replace_with_strong_password

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Trading config ---
MAX_POSITION_SIZE_SOL=0.05
MAX_CONCURRENT_POSITIONS=2
MIN_SCORE_TO_BUY=75
MIN_SCORE_TO_ALERT=65
SLIPPAGE_BPS=1500                     # 15% — memecoin perlu cap tinggi
PRIORITY_FEE_MICROLAMPORTS=10000      # 10k microLamports/CU baseline
JITO_TIP_LAMPORTS=1000000             # 0.001 SOL — minimum Helius Sender

# --- Position management ---
TP1_GAIN_PCT=80                       # +80% → sell 30%
TP1_SELL_PCT=30
TP2_GAIN_PCT=150
TP2_SELL_PCT=30
TP3_GAIN_PCT=300
TP3_SELL_PCT=25
HARD_SL_PCT=-45                       # -45% → full exit
TIME_BASED_EXIT_MINUTES=45            # auto sell kalau no momentum dalam X menit
TRAILING_STOP_PCT=30                  # trailing stop dari peak

# --- Circuit breaker (DECOUPLED watchdog) ---
CB_ENABLED=true
CB_CONSECUTIVE_LOSS_LIMIT=3
CB_CONSECUTIVE_LOSS_PAUSE_HOURS=6
CB_DAILY_LOSS_PCT=30
CB_WEEKLY_LOSS_PCT=50
CB_MAX_DRAWDOWN_PCT=50
CB_WIN_RATE_MIN_PCT=25
CB_WIN_RATE_WINDOW=20
CB_DRAWDOWN_VELOCITY_PCT=20
CB_DRAWDOWN_VELOCITY_WINDOW_MINUTES=60

# --- Scoring weights ---
SCORE_WEIGHT_SMART_MONEY=35
SCORE_WEIGHT_MCAP_POSITION=20
SCORE_WEIGHT_VOLUME_MOMENTUM=15
SCORE_WEIGHT_LIQUIDITY=10
SCORE_WEIGHT_SECURITY=10
SCORE_WEIGHT_KOL_SOCIAL=5
SCORE_PENALTY_BUNDLE=-10

# --- Filter awal (hard reject) ---
FILTER_MAX_MCAP_USD=60000
FILTER_MIN_LIQUIDITY_USD=8000
FILTER_MIN_GMGN_SECURITY_SCORE=70
FILTER_MAX_DEV_HOLDING_PCT=15
FILTER_MAX_BUNDLE_SUPPLY_PCT=30

# --- Rate limit (informational, hardcoded di client) ---
# Helius free: 10 RPC req/s, 1M credits/month, 5 WS connections
# GMGN free: leaky-bucket rate=10 capacity=10

# === PHASE 7: Multi-Source Intelligence ===

# --- Nansen (Smart money intelligence, token research, indicators) ---
# Sign up at https://app.nansen.ai (Pro tier or x402 micropayment)
NANSEN_API_KEY=replace_with_nansen_api_key
NANSEN_BASE_URL=https://api.nansen.ai
NANSEN_DAILY_CREDIT_CAP=300                # halt Nansen calls if exceeded

# --- Birdeye (Token overview, security, holders, price) ---
# Optional — most endpoints work without key, premium endpoints need key
# Sign up at https://birdeye.so for API key
BIRDEYE_API_KEY=                            # optional, leave empty for public-only

# --- Pump.fun (Bonding curve, graduation tracking) ---
# Public API, no key needed
PUMPFUN_BASE_URL=https://frontend-api-v3.pump.fun

# --- Intel Layer Flags ---
INTEL_MULTI_SOURCE_VERIFY_ENABLED=true       # 5-source token verification
INTEL_CLUSTER_DETECTION_ENABLED=true         # GMGN cluster signal detection
INTEL_NANSEN_TREND_ENABLED=true              # Nansen smart money trend (sustained/fresh/distribution)
INTEL_PUMPFUN_TRACKING_ENABLED=true          # Pump.fun graduation tracking

# --- Optional: GMGN Swap Alternative (instead of Jupiter+Helius) ---
EXECUTION_PROVIDER=jupiter                   # jupiter | gmgn

# === PHASE 6: AI Agent Layer (Optional) ===
# Master switches (default OFF — opt-in after Phase 1-5 stable)
AI_ENABLED=false
AI_RUG_CHECK_ENABLED=false                   # Pre-trade LLM rug check
AI_REFLECTION_ENABLED=false                  # Post-trade reflection learning loop
AI_WALLET_ASSESSMENT_ENABLED=false           # Smart wallet quality LLM classifier
AI_TUNER_ENABLED=false                       # Weekly param tuner (cron)

# Provider — OpenRouter as multi-LLM abstraction layer
# Sign up at https://openrouter.ai and top up $5 (cukup 1-3 bulan)
OPENROUTER_API_KEY=                          # leave empty if AI_ENABLED=false
LLM_FAST_MODEL=google/gemini-2.0-flash       # high-volume (rug check, sentiment)
LLM_REASONING_MODEL=anthropic/claude-haiku-4.5  # nuanced (reflection, wallet quality)
LLM_PREMIUM_MODEL=anthropic/claude-sonnet-4.6   # weekly tuner only

# Cost controls
LLM_DAILY_COST_CAP_USD=1.00                  # halt LLM calls if exceeded
LLM_TIMEOUT_SECONDS=10
LLM_MAX_RETRIES=1

# Confidence thresholds
AI_RUG_VETO_MIN_CONFIDENCE=0.8
AI_WALLET_BLACKLIST_MIN_CONFIDENCE=0.85

# === PHASE 8: Production Polish ===
HEALTH_PORT=8080                             # /health endpoint port (localhost)
METRICS_ENABLED=true                         # Prometheus metrics at /metrics
