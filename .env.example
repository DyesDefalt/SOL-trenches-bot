# =============================================================================
# Solana Sniper Bot - Environment Configuration
# =============================================================================
# Copy ke .env (or secrets/.env), isi dengan credential asli.
# JANGAN PERNAH commit .env ke git.
# Set permission: chmod 600 .env
# =============================================================================

# --- Mode ---
DRY_RUN=true                          # WAJIB true sampai backtest valid + smoke test sukses
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
ENV=development                       # development | production

# Virtual balance for DRY_RUN paper trading. Bot pretends to have this much
# SOL so you can simulate trades without funding the real wallet. Set as high
# as you want — e.g. 1.0 for real-modal simulation, 10.0 for a "what if I had
# more capital" simulation. Only used when DRY_RUN=true; ignored when LIVE.
PAPER_INITIAL_BALANCE_SOL=1.0

# --- Helius ---
HELIUS_API_KEY=replace_with_helius_api_key
# URL constructed at runtime; jangan ganti template ini kecuali tahu konsekuensinya
HELIUS_RPC_URL=https://mainnet.helius-rpc.com
HELIUS_WSS_URL=wss://mainnet.helius-rpc.com

# --- GMGN ---
GMGN_API_KEY=replace_with_gmgn_api_key
GMGN_PRIVATE_KEY_PATH=secrets/gmgn_private.pem
GMGN_BASE_URL=https://gmgn.ai

# --- Solana Wallet ---
WALLET_PATH=secrets/bot-wallet.json
WALLET_PUBLIC_KEY=replace_with_bot_wallet_public_address
SOLANA_RPC_URL=https://mainnet.helius-rpc.com  # akan diisi otomatis kalau pakai Helius

# --- Telegram ---
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_CHAT_ID=replace_with_chat_id

# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=solana_bot
POSTGRES_USER=bot
POSTGRES_PASSWORD=replace_with_strong_password

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Trading config ---
# Defaults tuned for *frequent paper trading*. AI rug-check + safety filters
# remain strict, so even at score 60 obvious scams are rejected. Tighten
# (e.g. 75+, 2 positions) once you've validated paper-trade outcomes.
MAX_POSITION_SIZE_SOL=0.05
MAX_CONCURRENT_POSITIONS=3            # was 2 — allow a 3rd concurrent position
MIN_SCORE_TO_BUY=60                   # was 75 — wider funnel for more trades
MIN_SCORE_TO_ALERT=45                 # was 65 — see borderline tokens in TG
SLIPPAGE_BPS=1500                     # 15% — memecoin perlu cap tinggi
PRIORITY_FEE_MICROLAMPORTS=10000      # 10k microLamports/CU baseline
JITO_TIP_LAMPORTS=1000000             # 0.001 SOL — minimum Helius Sender

# --- Position management ---
TP1_GAIN_PCT=80                       # +80% → sell 30%
TP1_SELL_PCT=30
TP2_GAIN_PCT=150
TP2_SELL_PCT=30
TP3_GAIN_PCT=300
TP3_SELL_PCT=25
HARD_SL_PCT=-45                       # -45% → full exit
TIME_BASED_EXIT_MINUTES=45            # auto sell kalau no momentum dalam X menit
TRAILING_STOP_PCT=30                  # trailing stop dari peak

# --- Circuit breaker (DECOUPLED watchdog) ---
CB_ENABLED=true
CB_CONSECUTIVE_LOSS_LIMIT=3
CB_CONSECUTIVE_LOSS_PAUSE_HOURS=6
CB_DAILY_LOSS_PCT=30
CB_WEEKLY_LOSS_PCT=50
CB_MAX_DRAWDOWN_PCT=50
CB_WIN_RATE_MIN_PCT=25
CB_WIN_RATE_WINDOW=20
CB_DRAWDOWN_VELOCITY_PCT=20
CB_DRAWDOWN_VELOCITY_WINDOW_MINUTES=60

# --- Scoring weights ---
SCORE_WEIGHT_SMART_MONEY=35
SCORE_WEIGHT_MCAP_POSITION=20
SCORE_WEIGHT_VOLUME_MOMENTUM=15
SCORE_WEIGHT_LIQUIDITY=10
SCORE_WEIGHT_SECURITY=10
SCORE_WEIGHT_KOL_SOCIAL=5
SCORE_PENALTY_BUNDLE=-10

# --- Filter awal (hard reject) ---
# Widened to allow mid-cap memes too (was 60k → now 500k). Security guards
# unchanged — bot still rejects high dev-holding / high bundler-rate tokens.
FILTER_MAX_MCAP_USD=500000            # was 60k — mid-cap memes allowed
FILTER_MIN_LIQUIDITY_USD=5000         # was 8k — slightly more lenient
FILTER_MIN_GMGN_SECURITY_SCORE=70
FILTER_MAX_DEV_HOLDING_PCT=15
FILTER_MAX_BUNDLE_SUPPLY_PCT=30

# --- Rate limit (informational, hardcoded di client) ---
# Helius free: 10 RPC req/s, 1M credits/month, 5 WS connections
# GMGN free: leaky-bucket rate=10 capacity=10

# === PHASE 7: Multi-Source Intelligence ===

# --- Nansen (Smart money intelligence, token research, indicators) ---
# Sign up at https://app.nansen.ai (Pro tier or x402 micropayment)
NANSEN_API_KEY=replace_with_nansen_api_key
NANSEN_BASE_URL=https://api.nansen.ai
NANSEN_DAILY_CREDIT_CAP=300                # halt Nansen calls if exceeded

# --- Birdeye (Token overview, security, holders, price) ---
# Optional — most endpoints work without key, premium endpoints need key
# Sign up at https://birdeye.so for API key
BIRDEYE_API_KEY=                            # optional, leave empty for public-only

# --- Pump.fun (Bonding curve, graduation tracking) ---
# Public API, no key needed
PUMPFUN_BASE_URL=https://frontend-api-v3.pump.fun

# --- Intel Layer Flags ---
INTEL_MULTI_SOURCE_VERIFY_ENABLED=true       # 5-source token verification
INTEL_CLUSTER_DETECTION_ENABLED=true         # GMGN cluster signal detection
INTEL_NANSEN_TREND_ENABLED=true              # Nansen smart money trend (sustained/fresh/distribution)
INTEL_PUMPFUN_TRACKING_ENABLED=true          # Pump.fun graduation tracking

# --- Optional: GMGN Swap Alternative (instead of Jupiter+Helius) ---
EXECUTION_PROVIDER=jupiter                   # jupiter | gmgn

# === PHASE 6: AI Agent Layer (Optional) ===
# Master switches (default OFF — opt-in after Phase 1-5 stable)
AI_ENABLED=false
AI_RUG_CHECK_ENABLED=false                   # Pre-trade LLM rug check
AI_REFLECTION_ENABLED=false                  # Post-trade reflection learning loop
AI_WALLET_ASSESSMENT_ENABLED=false           # Smart wallet quality LLM classifier
AI_TUNER_ENABLED=false                       # Weekly param tuner (cron)

# Provider — OpenRouter as multi-LLM abstraction layer
# Sign up at https://openrouter.ai and top up $5 (cukup 1-3 bulan)
OPENROUTER_API_KEY=                          # leave empty if AI_ENABLED=false
# `openrouter/free` is OpenRouter's magic router that auto-picks a free model
# with the capabilities the request needs (e.g. structured-output support
# when response_format=json_object is set). $0 cost. Used by
# FallbackLLMClient whenever it falls back to OpenRouter (caller's model id
# is discarded — fallback always uses this default). Override with explicit
# free ids like `google/gemini-2.0-flash-exp:free` or paid ids like
# `anthropic/claude-haiku-4.5` if OPENROUTER_API_KEY has credits.
OPENROUTER_DEFAULT_MODEL=openrouter/free

# LLM_FAST/REASONING/PREMIUM_MODEL = model ids used by the PRIMARY provider.
# Values below assume LLM_PROVIDER=openclaw (default). Switch to OpenRouter
# ids (e.g. `google/gemini-2.0-flash-exp:free`, `anthropic/claude-haiku-4.5`)
# if you flip LLM_PROVIDER=openrouter. The fallback target (OpenRouter when
# LLM_FALLBACK_PROVIDER=openrouter) IGNORES these and uses
# OPENROUTER_DEFAULT_MODEL, so cross-provider mismatches still recover.
LLM_FAST_MODEL=sg-combo                       # your 9router combo (auto-routes)
LLM_REASONING_MODEL=cc/claude-haiku-4-5-20251001  # Claude.com via 9router (cc/)
LLM_PREMIUM_MODEL=cc/claude-sonnet-4-6        # Claude.com via 9router (cc/)

# Cost controls
LLM_DAILY_COST_CAP_USD=1.00                  # halt LLM calls if exceeded
LLM_TIMEOUT_SECONDS=10
LLM_MAX_RETRIES=1

# Confidence thresholds
AI_RUG_VETO_MIN_CONFIDENCE=0.8
AI_WALLET_BLACKLIST_MIN_CONFIDENCE=0.85

# === PHASE 8: Production Polish ===
HEALTH_PORT=8080                             # /health endpoint port (localhost)
METRICS_ENABLED=true                         # Prometheus metrics at /metrics

# === PHASE 9: Extended Intelligence (macro + news + cross-ref + alt LLM) ===

# --- CryptoQuant (Macro on-chain: BTC flows, MVRV, funding rates) ---
# Sign up at https://cryptoquant.com/settings/api
# Free tier limited; Pro tier ($29/mo) unlocks most endpoints
CRYPTOQUANT_API_KEY=
CRYPTOQUANT_BASE_URL=https://api.cryptoquant.com/v1

# --- Alpha Vantage (TradFi macro: SPX/DXY/VIX proxies) ---
# Free tier 25 req/day, 5 req/min — get key at https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=
ALPHAVANTAGE_BASE_URL=https://www.alphavantage.co

# --- News provider (cryptocurrency.cv — currently DISABLED) ---
# cryptocurrency.cv added Cloudflare BOT_BLOCKED protection — all calls
# return 403 from VPS IPs. The client now short-circuits silently when
# disabled (no log spam, no rate-limit risk). Set to true only when
# running from a residential IP / residential proxy.
CRYPTOCURRENCYCV_ENABLED=false
CRYPTOCURRENCYCV_BASE_URL=https://cryptocurrency.cv

# --- CryptoPanic (LEGACY / optional fallback, paid plan only after Apr 2026) ---
# v1 is DEPRECATED (404 HTML). v2 lives at /api/{API_PLAN}/v2/. Free Developer
# tier is DISCONTINUED April 1, 2026 — paid plan required. New deployments
# should use cryptocurrency.cv above. Leave CRYPTOPANIC_API_KEY blank to
# rely entirely on the free cryptocurrency.cv provider.
CRYPTOPANIC_API_KEY=
CRYPTOPANIC_API_PLAN=developer            # developer | growth | enterprise
CRYPTOPANIC_BASE_URL=https://cryptopanic.com/api/developer/v2

# --- Messari (Asset profile + research, currently DISABLED) ---
# Most metrics endpoints now require Enterprise tier ($1k+/mo) — basic
# keys get 401 "Enterprise membership required". Client short-circuits
# silently when disabled. Set MESSARI_ENABLED=true ONLY if you have an
# Enterprise key. CoinGecko cross-ref below covers the same use case
# for free, so most users should leave this off.
MESSARI_ENABLED=false
MESSARI_API_KEY=
MESSARI_BASE_URL=https://api.messari.io

# --- CoinGecko (Cross-ref: listing + market cap rank + trending) ---
# Demo (free) 30 req/min, 10k req/month — sign up at https://www.coingecko.com/en/developers/dashboard
# Demo keys start with "CG-" → auto-routes to public-api endpoint
COINGECKO_API_KEY=
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# --- Tokito alternative LLM (OpenAI-compatible, model: pecut-ai) ---
# OAI-compatible endpoint — set LLM_PROVIDER=tokito to use as primary
TOKITO_API_KEY=
TOKITO_BASE_URL=https://api.tokito.xyz/v1
TOKITO_MODEL=pecut-ai
LLM_PROVIDER=openclaw                        # openclaw (primary) | openrouter | tokito — see OpenClaw block below

# --- Phase 9 feature flags ---
MACRO_REGIME_ENABLED=true                    # Detect BTC/SPX/DXY regime → throttle size
MACRO_REGIME_POSITION_THROTTLE_ENABLED=true  # Apply macro_multiplier to position_size_sol
NEWS_NARRATIVE_ENABLED=true                  # Boost score on narrative match
NEWS_FUD_DETECTION_ENABLED=true              # Hard-reject on high-severity FUD
CROSSREF_VALIDATION_ENABLED=true             # CoinGecko/Messari listing bonus

# === PHASE 10: Charon Parity + Trader Filters + AI Quality ===

# --- Hot-reloadable strategy manager (DB-backed) ---
STRATEGY_CACHE_TTL_SECONDS=5                 # in-memory cache TTL
STRATEGY_ENABLE_DB_OVERRIDE=true             # if false, always use .env (legacy mode)

# --- Dip-buy entry mode (wait for ATH/dump trigger) ---
DIP_BUY_DEFAULT_EXPIRES_HOURS=24             # expire pending alerts after 24h
DIP_BUY_CHECK_INTERVAL_SECONDS=30            # poll prices every 30s
DIP_BUY_MAX_PENDING_ALERTS=50                # cap pending alerts (cost protection)

# --- Pump.fun fee-claim WebSocket listener ---
FEECLAIM_ENABLED=true                        # 4th independent signal source
FEECLAIM_MIN_SOL=0.5                         # ignore claims below 0.5 SOL distributed
FEECLAIM_DEDUP_WINDOW_MINUTES=10

# --- Phase 10.5: Trader filters bundle (anti-bundler + global fee + funded-from + holder balance) ---
TRADER_FILTERS_ENABLED=true                  # multi-wallet bundler detection + fake volume + sniper detection
TRADER_FILTERS_HARD_REJECT_ENABLED=true      # if false, bundler/wash → score penalty only

# --- Phase 10.6: AI Meme Quality Scorer ---
AI_MEME_QUALITY_ENABLED=false                # opt-in: LLM evaluates meme creativity/virality/originality
MEME_QUALITY_CACHE_TTL_SECONDS=300
MEME_QUALITY_MIN_SCORE_TO_BOOST=60           # below 60 → no bonus
MEME_QUALITY_SCORE_MAX_BONUS=10.0

# --- Phase 10.6: Fibonacci 0.786 entry timing ---
FIB_ENTRY_ENABLED=false                      # opt-in: wait for 0.786 retracement before buying
FIB_ENTRY_DEFAULT_TIMEFRAME=5m
FIB_ENTRY_LOOKBACK_PERIODS=100               # 100 × 5m = ~8h lookback
FIB_ENTRY_TARGET_LEVEL=0.786                 # @badidoyo recommendation (less crowded than 0.618)
FIB_ENTRY_MIN_DROP_PCT=5.0                   # below 5% drop → enter now, don't wait
FIB_ENTRY_MIN_SWING_RATIO=1.5                # need at least 50% move for fib to apply

# --- OpenClaw / 9router (Phase 9b — recommended primary LLM) ---
# OpenAI-compatible multi-model relay. Run /v1/models on the endpoint
# to list all available model ids; `sg-combo` auto-routes to the best
# underlying model. The endpoint is IP-whitelisted, so the VPS must
# already be on the allowlist before requests succeed.
OPENCLAW_API_KEY=                                # sign up at the 9router admin to obtain
OPENCLAW_BASE_URL=http://43.163.86.112:20128/v1  # change to https:// when hosted publicly
OPENCLAW_DEFAULT_MODEL=sg-combo                  # or cc/claude-sonnet-4-6, cx/gpt-5.5, etc.

# Wire LLM_PROVIDER+LLM_FALLBACK_PROVIDER for a primary+fallback chain.
# Examples:
#   LLM_PROVIDER=openclaw  + LLM_FALLBACK_PROVIDER=openrouter (current default)
#   LLM_PROVIDER=openrouter + LLM_FALLBACK_PROVIDER=none     (single-provider, no chain)
LLM_FALLBACK_PROVIDER=openrouter                 # none | openrouter | tokito | openclaw
